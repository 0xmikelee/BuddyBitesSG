        <p class="text-balance text-center text-[16px] font-light md:text-left">
          At Buddy Bites, great nutrition starts with great ingredients. We use fresh proteins and vegetables, and
          naturally functional superfoods sourced from trusted regions around the world. Each recipe is thoughtfully
          made with prebiotics and Omega‑rich ingredients to support healthy digestion, shiny coats, strong teeth, and
          overall wellbeing , so even the fussiest pets can enjoy food that’s as nutritious as it is tasty!
        </p>
      </div>
      <div class="swiper swiper-raw-ingredients w-full">
        <div class="swiper-wrapper">
          {% for ingredient in shop.metaobjects.premium_ingredients.values %}
            <div class="swiper-slide">
              <div class="flex h-[230px] flex-col items-start justify-start gap-2">
                <img
                  src="{{ ingredient.image | image_url: width: 150 }}"
                  alt="{{ ingredient.name }}"
                  class="rounded-[20px] object-cover"
                >
                <div class="flex h-full flex-col items-start justify-end gap-2">
                  <p class="text-[14px] font-normal text-[#A3A3A3]">{{ ingredient.key_benefit }}</p>
                  <p class=" text-[14px] font-semibold">{{ ingredient.name }}</p>
                  <p class=" text-balance text-[14px] font-normal">{{ ingredient.content }}</p>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
        <div class="swiper-pagination"></div>
      </div>
    </div>
  </section>
