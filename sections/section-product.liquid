<main>
  <section class="container py-5 md:py-10">
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      {% comment %} Product Image {% endcomment %}
      <div class="relative h-full">
        <div class="sticky top-0 h-fit w-full overflow-hidden rounded-3xl">
          <div class="swiper-product">
            <div class="swiper-button-prev"></div>
            <div class="swiper-wrapper">
              {% for image in product.media %}
                <div class="swiper-slide">
                  <img src="{{ image | img_url: 'master' }}" alt="{{ image.alt }}" class="h-full w-full object-cover">
                </div>
              {% endfor %}
            </div>
            <div class="swiper-button-next"></div>
          </div>
        </div>
      </div>
      {% comment %} Product Details {% endcomment %}
      <div class="relative flex h-full flex-col gap-2 p-5">
        <h2 class="m-0 text-[24px] font-bold text-[#193C6B] en:font-museo">{{ product.title }}</h2>
        <h3 class="prose prose-base marker:text-black prose-ul:list-disc">
          {{ product.description }}
        </h3>
        {% render 'snippet-add-to-cart' %}
      </div>
    </div>
  </section>
</main>

{% style %}
  .swiper-product {
    width: 100%;
    height: 100%;
    margin: 0 auto;
    overflow: hidden;
    position: relative;
  }
  .swiper-button-next,
  .swiper-button-prev {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 30px;
    height: 30px;
    z-index: 10;
  }
  .swiper-button-next {
    right: 10px;
  }
  .swiper-button-prev {
    left: 10px;
  }
{% endstyle %}

<script>
  const swiper = new Swiper('.swiper-product', {
    direction: 'horizontal',
    spaceBetween: 10,
    autoplay: false,
    loop: true,
    navigation: {
      nextEl: '.swiper-button-next',
      prevEl: '.swiper-button-prev',
    },
  });
</script>
{% schema %}
{
  "name": "Default Product Section",
  "settings": []
}
{% endschema %}
