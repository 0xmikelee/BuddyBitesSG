<main class="font-foundersGrotesk">
  <!-- Hero Section -->
  <section class="relative">
    <img
      src="{{ 'homepage_banner_2.png' | file_img_url: 'master' }}"
      alt="Hero Image"
      class="hidden h-full w-full object-cover md:block"
    >
    <img
      src="{{ 'homepage_banner_mobile_2.png' | file_img_url: 'master' }}"
      alt="Hero Image"
      class="block h-full w-full object-cover md:hidden"
    >
    <div class="absolute left-0 top-0 flex h-1/2 w-full flex-col items-start justify-center gap-8 px-4 text-left text-[#173C6A] md:h-full md:w-[40%] md:gap-6 md:px-10">
      <h1 class="text-balance font-titanOne text-[clamp(40px,5vw,55px)] leading-[clamp(40px,5vw,55px)]">
        Premium European Kibble
      </h1>
      <p class="text-balance text-[clamp(20px,2.5vw,25px)] font-medium leading-[clamp(30px,2.5vw,35px)]">
        Vet-backed formula, Gut-Friendly prebiotics. Nearly 10 million meals donated.
      </p>
      <a
        href="{{ pages['quiz'].url }}"
        class="rounded-full border-2 border-[#173C6A] bg-[#173C6A] px-5 py-2 font-montserrat text-[14px] font-semibold uppercase text-white hover:border-[#173C6A] hover:bg-white hover:text-[#173C6A]"
      >
        Take Our Quiz
      </a>
    </div>
  </section>
</main>

{% schema %}
{
  "name": "Homepage",
  "settings": []
}
{% endschema %}
