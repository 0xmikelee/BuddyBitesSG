{% style %}
  .swiper-fav-dog {
    width: 100%;
    height: 100%;
    margin: 0 auto;
    overflow: hidden;
  }
  .accordion-button[aria-expanded='true'] .accordion-icon:not(.faq-accordion-symbol) {
    transform: rotate(180deg);
  }
  .accordion-icon {
    transition: transform 0.2s;
  }
  .faq-accordion-symbol {
    transition: none;
  }

  .els-cup-box {
    height: auto !important;
    margin: 0 !important;
  }
  .els-cup-w {
    width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  .els-cup-w-val {
    font-size: 60px !important;
    line-height: 60px !important;
  }

  .els-cup-w-icon,
  .els-cup-w-descr {
    display: none !important;
  }

  @media (min-width: 1024px) {
    .els-cup-box {
      height: auto !important;
      margin-top: 30px !important;
    }

    .els-cup-w-val {
      font-size: 100px !important;
      line-height: 100px !important;
    }
  }
{% endstyle %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', function () {
    const favTabs = document.querySelectorAll('.btn-fav-tab');
    favTabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        // Remove active class from all tabs
        const spanClicked = tab.querySelector('.span-fav-tab');

        favTabs.forEach(function (t) {
          const span = t.querySelector('.span-fav-tab');
          span.classList.remove('span-fav-tab-active');
        });
        // Add active class to the clicked tab
        spanClicked.classList.add('span-fav-tab-active');
      });
    });

    const swiperFavDog = new Swiper('.swiper-fav-dog', {
      loop: true,
      autoplay: { delay: 2500, disableOnInteraction: false },
      slidesPerView: 1,
      spaceBetween: 16,
      breakpoints: {
        320: { slidesPerView: 1, spaceBetween: 16 },
        1024: { slidesPerView: 3, spaceBetween: 16 },
      },
    });

    const swiperFavCat = new Swiper('.swiper-fav-cat', {
      loop: true,
      autoplay: { delay: 2500, disableOnInteraction: false },
      slidesPerView: 1,
      spaceBetween: 16,
      breakpoints: {
        320: { slidesPerView: 1, spaceBetween: 16 },
        1024: { slidesPerView: 3, spaceBetween: 16 },
      },
    });

    const swiperPartneringShelters = new Swiper('.swiper-partnering-shelters', {
      loop: true,
      autoplay: { delay: 2500, disableOnInteraction: false },
      slidesPerView: 1,
      spaceBetween: 16,
      breakpoints: {
        320: { slidesPerView: 3, spaceBetween: 24 },
        1024: { slidesPerView: 5, spaceBetween: 40 },
      },
    });

    const btnFavDog = document.getElementById('btn-fav-dog');
    // const btnFavCat = document.getElementById('btn-fav-cat');
    const tabFavDog = document.getElementById('tab-fav-dog');
    const tabFavCat = document.getElementById('tab-fav-cat');

    btnFavDog.addEventListener('click', function () {
      tabFavDog.classList.remove('hidden');
      if (tabFavCat) tabFavCat.classList.add('hidden');
    });

    // btnFavCat.addEventListener('click', function () {
    //   tabFavDog.classList.add('hidden');
    //   tabFavCat.classList.remove('hidden');
    // });

    function setAccordionIconState(icon, isExpanded) {
      if (!icon) return;
      if (icon.classList.contains('faq-accordion-symbol')) {
        icon.textContent = isExpanded ? '\u2212' : '+';
        return;
      }
      icon.classList.toggle('rotate-180', isExpanded);
    }

    const accordionButtons = document.querySelectorAll('.accordion-button');
    accordionButtons.forEach((btn) => {
      btn.addEventListener('click', function () {
        console.log('btn clicked');
        const targetSelector = btn.getAttribute('data-accordion-target');
        const content = targetSelector ? document.querySelector(targetSelector) : null;
        if (!content) return;

        const root = btn.closest('.accordion');
        if (!root) return;

        const expanded = btn.getAttribute('aria-expanded') === 'true';

        root.querySelectorAll('.accordion-collapse').forEach((panel) => {
          panel.classList.add('hidden');
        });
        root.querySelectorAll('.accordion-button').forEach((otherBtn) => {
          otherBtn.setAttribute('aria-expanded', 'false');
          setAccordionIconState(otherBtn.querySelector('.accordion-icon'), false);
        });

        if (!expanded) {
          content.classList.remove('hidden');
          btn.setAttribute('aria-expanded', 'true');
          setAccordionIconState(btn.querySelector('.accordion-icon'), true);
        }
      });
    });
  });
{% endjavascript %}

