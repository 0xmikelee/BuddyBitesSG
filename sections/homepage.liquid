{% javascript %}
  document.addEventListener('DOMContentLoaded', function () {
    const favTabs = document.querySelectorAll('.btn-fav-tab');
    favTabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        // Remove active class from all tabs
        const spanClicked = tab.querySelector('.span-fav-tab');

        favTabs.forEach(function (t) {
          const span = t.querySelector('.span-fav-tab');
          span.classList.remove('span-fav-tab-active');
        });
        // Add active class to the clicked tab
        spanClicked.classList.add('span-fav-tab-active');
      });
    });

    const swiperFavDog = new Swiper('.swiper-fav-dog', {
      loop: true,
      autoplay: { delay: 2500, disableOnInteraction: false },
      slidesPerView: 1,
      spaceBetween: 16,
      breakpoints: {
        320: { slidesPerView: 1, spaceBetween: 16 },
        1024: { slidesPerView: 3, spaceBetween: 16 },
      },
    });

    const swiperFavCat = new Swiper('.swiper-fav-cat', {
      loop: true,
      autoplay: { delay: 2500, disableOnInteraction: false },
      slidesPerView: 1,
      spaceBetween: 16,
      breakpoints: {
        320: { slidesPerView: 1, spaceBetween: 16 },
        1024: { slidesPerView: 3, spaceBetween: 16 },
      },
    });

    const swiperPartneringShelters = new Swiper('.swiper-partnering-shelters', {
      loop: true,
      autoplay: { delay: 2500, disableOnInteraction: false },
      slidesPerView: 1,
      spaceBetween: 16,
      breakpoints: {
        320: { slidesPerView: 3, spaceBetween: 24 },
        1024: { slidesPerView: 9, spaceBetween: 40 },
      },
    });

    const btnFavDog = document.getElementById('btn-fav-dog');
    const btnFavCat = document.getElementById('btn-fav-cat');
    const tabFavDog = document.getElementById('tab-fav-dog');
    const tabFavCat = document.getElementById('tab-fav-cat');

    btnFavDog.addEventListener('click', function () {
      tabFavDog.classList.remove('hidden');
      tabFavCat.classList.add('hidden');
    });

    btnFavCat.addEventListener('click', function () {
      tabFavDog.classList.add('hidden');
      tabFavCat.classList.remove('hidden');
    });

    const accordionButtons = document.querySelectorAll('.accordion-button');
    accordionButtons.forEach((btn) => {
      btn.addEventListener('click', function () {
        // Fix: Get target by CSS id selector, not querySelector("#collapseX")
        const targetSelector = btn.getAttribute('data-accordion-target');
        const content = document.querySelector(targetSelector);

        if (!content) return;

        // Check if this panel is open
        const expanded = btn.getAttribute('aria-expanded') === 'true';

        // Hide all panels and reset buttons
        document.querySelectorAll('.accordion-collapse').forEach((panel) => {
          panel.classList.add('hidden');
        });
        document.querySelectorAll('.accordion-button').forEach((otherBtn) => {
          otherBtn.setAttribute('aria-expanded', 'false');
          if (otherBtn.querySelector('.accordion-icon')) {
            otherBtn.querySelector('.accordion-icon').classList.remove('rotate-180');
          }
        });

        // Show this panel if it wasn't expanded
        if (!expanded) {
          content.classList.remove('hidden');
          btn.setAttribute('aria-expanded', 'true');
          if (btn.querySelector('.accordion-icon')) {
            btn.querySelector('.accordion-icon').classList.add('rotate-180');
          }
        }
      });
    });
  });
{% endjavascript %}

