              </div>
            </div>
            <div class="swiper-slide">
              <div class="flex w-full flex-col items-center justify-center gap-4 rounded-[20px] bg-white p-4">
                <img
                  src="{{ 'kitten_kibbles_chicken_front.png' | file_img_url: 'master' }}"
                  alt="Kitten Chicken Kibbles"
                  class="w-full rounded-[20px] object-cover"
