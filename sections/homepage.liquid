                    <p>Kitten Kibbles</p>
                    <p>$7.20</p>
                  </div>
                  <p class="text-[14px] font-normal">Kitten Chicken Recipe</p>
                </div>
                <a href="{{ all_products['kitten-chicken-dry-cat-food'].url }}" class="btn-buy-now w-full">
                  Add to Cart - $7.20
